# Database settings
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=girnar_db

# JWT settings
# Generate a new random value - never reuse Little Loot's secret
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Girnar's own domains only, never a wildcard
CORS_ORIGINS=https://girnargifts.com,https://www.girnargifts.com

# Cloudinary settings - Girnar's own account (or at least a separate folder)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=girnar-gifts

# Razorpay - Girnar's own account/keys, never reuse Little Loot's
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_RECEIPT_PREFIX=girnar_

# Brand (used in emails/invoices)
BRAND_NAME=Girnar Gifts
BRAND_SUPPORT_EMAIL=support@girnargifts.com
BRAND_GSTIN=your-gstin-here

# Newsletter (optional)
RESEND_API_KEY=your-resend-api-key
NEWSLETTER_FROM_EMAIL=support@girnargifts.com
NEXT_PUBLIC_FRONTEND_URL=https://girnargifts.com

# WhatsApp (optional - leave unset to keep the notification adapter as a no-op stub)
WHATSAPP_PROVIDER=aisensy
WHATSAPP_API_KEY=
WHATSAPP_SENDER=

# Shiprocket webhook (optional - leave unset to keep the webhook inert)
SHIPROCKET_WEBHOOK_TOKEN=

# Admin seeding (never hardcode - passed at runtime only)
# SEED_ADMIN_EMAIL=admin@girnargifts.com
# SEED_ADMIN_PASSWORD=